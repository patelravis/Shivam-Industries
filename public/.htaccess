<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # Social crawlers (WhatsApp, Facebook, etc.) get OG meta HTML for product pages
  RewriteCond %{HTTP_USER_AGENT} (facebookexternalhit|WhatsApp|Twitterbot|LinkedInBot|Slackbot|TelegramBot|Discordbot) [NC]
  RewriteRule ^product/([a-z0-9-]+)/?$ og/product.php?slug=$1 [L,QSA]

  # SPA fallback — all other routes serve index.html
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule . /index.html [L]
</IfModule>
